bbcode_enabled = true
text = "[color=black]The [b]drop bear[/b] (sometimes [b]dropbear[/b]) is a very real[color=blue][b][i][1][/i][/b][/color] [color=black]predatory, carnivorous version of the koala. They are alleged by some[color=blue][b][i][citation needed][/i][/b][/color] to especially feed on Australian tourists.
Studies indicate[color=blue][b][i][2][/i][/b][/color] that drop bears are mostly just stressed, and will become peaceful if [color=blue][u]relaxed[/u][/color]."

